{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Next.js",
    "extends": "./base.json",
    "compilerOptions": {
      "target": "ES5",
      "lib": ["DOM", "DOM.Iterable", "ESNext"],
      "noEmit": true,
      "esModuleInterop": true,
      "module": "ESNext",
      "resolveJsonModule": true,
      "jsx": "preserve",
      "incremental": true,
      "allowJs": true
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules"]
  }
  