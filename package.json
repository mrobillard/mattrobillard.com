    "build": "turbo run build --",
    "start": "turbo run start --no-cache --parallel --continue --"
  },
  "devDependencies": {
    "@commitlint/cli": "16.2.3",
    "@commitlint/config-conventional": "16.2.1",
    "husky": "7.0.4",
    "prettier": "2.6.2",
    "turbo": "1.2.4"
  }
}
